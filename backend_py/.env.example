# MIVE Backend — copy to .env and fill
APP_NAME=MIVE
DEBUG=false

# Database (async for app)
DATABASE_URL=postgresql+asyncpg://mive:mive@localhost:5432/mive
DATABASE_URL_SYNC=postgresql://mive:mive@localhost:5432/mive

# Redis (optional for workers)
REDIS_URL=redis://localhost:6379/0

# LLM / Embeddings (optional; mock used if empty)
OPENAI_API_KEY=
OPENAI_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Ingestion
ALPHA_VANTAGE_API_KEY=
FED_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml
ECB_RSS_URL=https://www.ecb.europa.eu/rss/press.html
INGESTION_INTERVAL_MINUTES=15

# Clustering
CLUSTERING_WINDOW_HOURS=48
MIN_CLUSTER_SIZE=2
MIN_SAMPLES=1

# Auto-trigger
AUTO_TRIGGER_SURPRISE_THRESHOLD_SD=0.3
AUTO_TRIGGER_HEAT_THRESHOLD=70
SIMULATION_COOLDOWN_SECONDS=300

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
