# =============================================================================
# MIVE — Macro-Intelligence & Valuation Engine
# Environment variables for external APIs and runtime
# =============================================================================
# Copy this file to .env and fill in values. Do not commit .env.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------------------
# Economic & market data (optional for MVP; enables live macro-driven logic)
# -----------------------------------------------------------------------------

# Alpha Vantage — economic indicators, FX, equities
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance — no key required for public data; set if using a proxy or wrapper
# YAHOO_FINANCE_API_KEY=

# CoinGecko — crypto; free tier, no key required. Optional key for higher rate limit.
# COINGECKO_API_KEY=

# -----------------------------------------------------------------------------
# Central bank / official data (RSS or public APIs; usually no key)
# -----------------------------------------------------------------------------
# Fed, ECB, MAS, BoE etc. are ingested via RSS or scraping. No env vars needed.
# Optional: proxy or auth if you add premium sources later.
# FED_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml

# -----------------------------------------------------------------------------
# AI / LLM (for agent narratives and Horizon View explanations — Phase 2)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# Or: ANTHROPIC_API_KEY= | together_api_key= etc. depending on provider

# -----------------------------------------------------------------------------
# Vector DB / embeddings (for Institutional Memory — Phase 2)
# -----------------------------------------------------------------------------
# PINECONE_API_KEY=
# PINECONE_INDEX=
# Or: DATABASE_URL= for pgvector

# -----------------------------------------------------------------------------
# Feature flags (optional)
# -----------------------------------------------------------------------------
# ENABLE_LIVE_MACRO_FEED=false
# ENABLE_AGENT_SIMULATION=false
